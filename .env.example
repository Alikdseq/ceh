DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Docker: базовый Python-образ (если Docker Hub тормозит — оставьте mirror.gcr.io)
PYTHON_IMAGE=mirror.gcr.io/library/python:3.12-slim
DATABASE_URL=postgres://ekontaktor:ekontaktor@db:5432/ekontaktor
REDIS_URL=redis://redis:6379/0

# Production (Docker backend image includes /app/catalog-tovar from frontend/public/tovar)
# CATALOG_TOVAR_DIR=/app/catalog-tovar
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SSR inside Docker (server components)
INTERNAL_API_URL=http://backend:8000/api/v1
# Django CSRF / CORS for browser → Next proxy → backend
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (Docker dev: Mailhog at http://localhost:8025 — письма не уходят в реальный Gmail)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@ekontaktor.ru
# Для реальной почты в dev раскомментируйте и укажите SMTP (Gmail — пароль приложения):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Предварительно из ekontaktor.ru — подтвердить в data/CLIENT_INPUT.md
ORDER_EMAILS=info@ekontaktor.ru,elkonreal@yandex.ru

# CRM
CRM_WEBHOOK_URL=

# Admin
ADMIN_URL=manage/
DJANGO_SUPERUSER_EMAIL=admin@ekontaktor.ru
DJANGO_SUPERUSER_PASSWORD=admin123

# Dev: auto-activate this email for news notifications (double opt-in still works for others)
TEST_NEWSLETTER_EMAIL=alihanskaev@gmail.com

# SEO / IndexNow (prod: create frontend/public/{INDEXNOW_KEY}.txt containing the key)
INDEXNOW_KEY=
INDEXNOW_ENABLED=false

# MinIO / S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ekontaktor
AWS_S3_ENDPOINT_URL=http://minio:9000
USE_S3=False
