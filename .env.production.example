# =============================================================================
# Production — https://www.ekontaktor.ru
# Скопируйте на сервер: cp .env.production.example .env
# =============================================================================

# --- Django ---
SECRET_KEY=ЗАМЕНИТЕ-НА-СЛУЧАЙНУЮ-СТРОКУ-50-СИМВОЛОВ
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=ekontaktor.ru,www.ekontaktor.ru,backend
ADMIN_URL=manage/

# --- База данных ---
POSTGRES_DB=ekontaktor
POSTGRES_USER=ekontaktor
POSTGRES_PASSWORD=ЗАМЕНИТЕ-НА-СИЛЬНЫЙ-ПАРОЛЬ
DATABASE_URL=postgres://ekontaktor:ЗАМЕНИТЕ-НА-СИЛЬНЫЙ-ПАРОЛЬ@db:5432/ekontaktor
REDIS_URL=redis://redis:6379/0

# --- Домены (канонический — www) ---
FRONTEND_URL=https://www.ekontaktor.ru
NEXT_PUBLIC_SITE_URL=https://www.ekontaktor.ru
NEXT_PUBLIC_API_URL=https://www.ekontaktor.ru/api/v1
CORS_ALLOWED_ORIGINS=https://ekontaktor.ru,https://www.ekontaktor.ru
CSRF_TRUSTED_ORIGINS=https://ekontaktor.ru,https://www.ekontaktor.ru

# --- Почта (SMTP Beget или корпоративная) ---
EMAIL_HOST=smtp.beget.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=noreply@ekontaktor.ru
EMAIL_HOST_PASSWORD=ПАРОЛЬ-ОТ-ПОЧТЫ
DEFAULT_FROM_EMAIL=noreply@ekontaktor.ru
ORDER_EMAILS=info@ekontaktor.ru,elkonreal@yandex.ru

# --- Админ (только для первого создания; потом смените пароль) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ekontaktor.ru
DJANGO_SUPERUSER_PASSWORD=ЗАМЕНИТЕ-СРАЗУ-ПОСЛЕ-ДЕПЛОЯ

# --- Документы акционерам (монтируется ./docs → /docs) ---
CORPORATE_DOCS_ROOT=/docs

# --- Опционально ---
SENTRY_DSN=
CRM_WEBHOOK_URL=
INDEXNOW_KEY=
INDEXNOW_ENABLED=false
SECURE_SSL_REDIRECT=False

# --- Docker build (если Docker Hub медленный) ---
PYTHON_IMAGE=mirror.gcr.io/library/python:3.12-slim
